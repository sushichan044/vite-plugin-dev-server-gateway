    "name": "sushichan044",
    "url": "https://github.com/sushichan044"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sushichan044/vite-plugin-dev-server-gateway.git",
    "directory": "packages/vite-plugin-dev-server-gateway"
  },
  "funding": "https://github.com/sponsors/sushichan044",
  "bin": {
    "vite-plugin-dev-server-gateway": "./dist/cli.mjs"
  },
